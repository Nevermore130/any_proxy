# Tencent Cloud public IP or DNS name shown in dashboard relay URLs.
RELA_CAPTURE_ADVERTISE_HOST=1.2.3.4

# Keep host and container ports aligned unless you also update app relay URLs.
RELA_CAPTURE_DASHBOARD_PORT=5177

# Rela app upstream.
RELA_RELAY_TARGET_ORIGIN=https://api.rela.me

RELA_CAPTURE_MAX_FLOWS=5000
RELA_CAPTURE_BODY_PREVIEW_BYTES=32768
RELA_CAPTURE_FLOW_TTL_SECONDS=600
