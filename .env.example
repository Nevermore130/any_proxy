# Tencent Cloud public IP or DNS name shown to phones and the Rela app relay config.
RELA_CAPTURE_ADVERTISE_HOST=1.2.3.4

# Keep host and container ports aligned unless you also update app relay URLs.
RELA_CAPTURE_DASHBOARD_PORT=5177
RELA_CAPTURE_PROXY_PORT=8088

# Rela app upstream.
RELA_RELAY_TARGET_ORIGIN=https://api.rela.me

# Docker deployment allows public clients by default. Restrict Tencent Cloud
# security groups to trusted networks until IP whitelist support is added.
RELA_CAPTURE_MITMPROXY_BLOCK_GLOBAL=false

RELA_CAPTURE_MAX_FLOWS=2000
RELA_CAPTURE_BODY_PREVIEW_BYTES=65536
